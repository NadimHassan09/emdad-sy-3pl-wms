# Admin UI → local NestJS API (proxied by Vite in dev — see vite.config.ts)
VITE_API_URL=/api
VITE_DEV_BACKEND_URL=http://127.0.0.1:3000

# JWT: access token is stored in sessionStorage after login; API uses Bearer + HttpOnly cookie.
# Tenant header for dev (seeded Acme Imports id) — also used by Socket.IO company room:
VITE_MOCK_COMPANY_ID=00000000-0000-4000-8000-000000000001
