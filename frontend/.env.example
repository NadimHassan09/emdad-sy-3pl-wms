VITE_API_URL=http://localhost:3000/api

# Optional default tenant header (`X-Company-Id`) for local dev. Should match a seeded company id
# (e.g. Acme Imports `00000000-0000-4000-8000-000000000001` from backend `npm run db:seed`).
# Also used by Socket.IO (`/realtime`) so internal users join the correct `company:{id}` room.
VITE_MOCK_COMPANY_ID=

# Optional UUID of the warehouse fixed in UI (single-warehouse mode fallback after active-first).
VITE_DEFAULT_WAREHOUSE_ID=

# Mirror TASK_ONLY_FLOWS for UX: inbound staging dock map, timelines, hides legacy Receive shortcut messaging.
VITE_TASK_ONLY_FLOWS=

# Worker UUID for production builds / CI (must match assigned worker to run tasks). Optional in `vite dev`:
# without it, dev uses the task assignee from the API as operator identity.
VITE_MOCK_WORKER_ID=

