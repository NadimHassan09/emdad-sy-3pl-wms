// EMDAD 3PL WMS — Phase 1 Prisma schema
//
// The full improved_schema.sql is applied as a raw baseline migration
// (prisma/migrations/0_init/migration.sql). This file therefore only models
// the subset of tables that Phase 1 operates on. Tables for tasks, qc_*,
// billing, allocations, reservations, idempotency_keys, etc. exist in the
// database but are intentionally not surfaced to the application yet.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

