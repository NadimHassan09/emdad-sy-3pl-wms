// ---------------------------------------------------------------------------
// CORE TABLES
// ---------------------------------------------------------------------------

model Company {
  id               String           @id @default(uuid()) @db.Uuid
  name             String
  tradeName        String?          @map("trade_name")
  contactEmail     String           @map("contact_email")
  contactPhone     String?          @map("contact_phone")
  address          String?
  city             String?
  country          String           @default("SA")
  vatNumber        String?          @map("vat_number")
  billingCycle     BillingCycleType @default(monthly) @map("billing_cycle")
  paymentTermsDays Int              @default(30) @map("payment_terms_days")
  status           CompanyStatus    @default(active)
  notes            String?
  workflowUxSettings Json?            @map("workflow_ux_settings") @db.JsonB
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)

  users          User[]
  products       Product[]
  inboundOrders  InboundOrder[]
  outboundOrders OutboundOrder[]
  returnOrders   ReturnOrder[]
  currentStock   CurrentStock[]
  ledgerEntries     InventoryLedger[]
  stockAdjustments       StockAdjustment[]
  cycleCountSchedules    CycleCountSchedule[]
  cycleCounts            CycleCount[]
  cycleCountVariances    CycleCountVariance[]
  cycleCountProductHistory CycleCountProductHistory[]
  workers                Worker[]
  workflowInstances      WorkflowInstance[]
  notifications          Notification[]
  userCompanyAccess      UserCompanyAccess[]
  billingPlans           BillingPlan[]
  billingCycles          BillingCycle[]
  invoices               Invoice[]

  @@map("companies")
}

model BillingPlan {
  id                      String   @id @default(uuid()) @db.Uuid
  companyId               String   @map("company_id") @db.Uuid
  active                  Boolean  @default(true)
  cycleLengthDays         Int      @map("cycle_length_days")
  fixedSubscriptionFee    Decimal  @default(0) @map("fixed_subscription_fee") @db.Decimal(12, 2)
  inboundOrderFee         Decimal  @default(0) @map("inbound_order_fee") @db.Decimal(10, 4)
  outboundOrderFee        Decimal  @default(0) @map("outbound_order_fee") @db.Decimal(10, 4)
  packagingFee            Decimal  @default(0) @map("packaging_fee") @db.Decimal(10, 4)
  qualityCheckFee         Decimal  @default(0) @map("quality_check_fee") @db.Decimal(10, 4)
  excessVolumeFeePerDay   Decimal  @default(0) @map("excess_volume_fee_per_day") @db.Decimal(10, 4)
  excessWeightFeePerDay   Decimal  @default(0) @map("excess_weight_fee_per_day") @db.Decimal(10, 4)
  reservedVolume          Decimal  @default(0) @map("reserved_volume") @db.Decimal(14, 4)
  reservedWeight          Decimal  @default(0) @map("reserved_weight") @db.Decimal(14, 4)
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  company       Company        @relation(fields: [companyId], references: [id])
  billingCycles BillingCycle[]

  @@index([companyId], map: "idx_billing_plans_company")
  @@map("billing_plans")
}

model BillingCycle {
  id            String             @id @default(uuid()) @db.Uuid
  companyId     String             @map("company_id") @db.Uuid
  billingPlanId String             @map("billing_plan_id") @db.Uuid
  startsAt      DateTime           @map("starts_at") @db.Timestamptz(6)
  endsAt        DateTime           @map("ends_at") @db.Timestamptz(6)
  status        BillingCycleStatus @default(active)
  rateSnapshot  Json               @default("{}") @map("rate_snapshot") @db.JsonB
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  company     Company     @relation(fields: [companyId], references: [id])
  billingPlan BillingPlan @relation(fields: [billingPlanId], references: [id])
  invoices    Invoice[]

  @@index([companyId, status], map: "idx_billing_cycles_company")
  @@map("billing_cycles")
}

model Invoice {
  id             String               @id @default(uuid()) @db.Uuid
  companyId      String               @map("company_id") @db.Uuid
  billingCycleId String               @map("billing_cycle_id") @db.Uuid
  invoiceNumber  String               @unique @default("") @map("invoice_number")
  status         BillingInvoiceStatus @default(draft)
  totalAmount    Decimal              @default(0) @map("total_amount") @db.Decimal(14, 2)
  issuedAt       DateTime?            @map("issued_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)

  company      Company       @relation(fields: [companyId], references: [id])
  billingCycle BillingCycle  @relation(fields: [billingCycleId], references: [id])
  lines        InvoiceLine[]

  @@index([companyId], map: "idx_invoices_company")
  @@index([billingCycleId], map: "idx_invoices_cycle")
  @@map("invoices")
}

model InvoiceLine {
  id         String                 @id @default(uuid()) @db.Uuid
  invoiceId  String                 @map("invoice_id") @db.Uuid
  type       BillingInvoiceLineType
  quantity   Decimal                @db.Decimal(15, 4)
  unitPrice  Decimal                @map("unit_price") @db.Decimal(10, 4)
  totalPrice Decimal                @map("total_price") @db.Decimal(14, 2)
  createdAt  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId], map: "idx_invoice_lines_invoice")
  @@map("invoice_lines")
}

/// Explicit internal-user grants to operate on a 3PL client tenant (Phase 1.1).
model UserCompanyAccess {
  userId    String   @map("user_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([companyId])
  @@map("user_company_access")
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  companyId     String?    @map("company_id") @db.Uuid
  email         String     @unique
  passwordHash  String     @map("password_hash")
  fullName      String     @map("full_name")
  phone         String?
  role          UserRole
  status        UserStatus @default(active)
  tokenVersion  Int        @default(0) @map("token_version")
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz(6)
  lastActivityAt DateTime? @map("last_activity_at") @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)

  company             Company?         @relation(fields: [companyId], references: [id])
  inboundOrdersOwned           InboundOrder[]           @relation("InboundCreatedBy")
  outboundOrdersOwned          OutboundOrder[]          @relation("OutboundCreatedBy")
  returnOrdersOwned            ReturnOrder[]            @relation("ReturnCreatedBy")
  returnOrdersCancelled        ReturnOrder[]            @relation("ReturnCancelledBy")
  ledgerEntries                InventoryLedger[]
  stockAdjustmentsCreated      StockAdjustment[]        @relation("AdjustmentCreatedBy")
  stockAdjustmentsApproved     StockAdjustment[]        @relation("AdjustmentApprovedBy")
  worker                  Worker?
  taskAssignmentsAssigned TaskAssignment[]           @relation("TaskAssignedBy")
  taskEvents              TaskEvent[]                @relation("TaskEventActor")
  warehouseTasksCompleted WarehouseTask[]            @relation("WarehouseTaskCompleter")
  notifications           Notification[]
  companyAccess           UserCompanyAccess[]
  authRefreshSessions     AuthRefreshSession[]
  cycleCountSchedulesCreated CycleCountSchedule[] @relation("CycleCountScheduleCreator")
  cycleCountsCreated         CycleCount[]         @relation("CycleCountCreator")
  cycleCountLinesCounted     CycleCountLine[]     @relation("CycleCountLineCounter")
  cycleCountVariancesReviewed CycleCountVariance[] @relation("CycleCountVarianceReviewer")
  returnLinesInspected        ReturnOrderLine[]    @relation("ReturnLineInspector")
  backupJobsTriggered         BackupJob[]          @relation("BackupTriggeredBy")
  backupSchedulesCreated      BackupSchedule[]     @relation("BackupScheduleCreatedBy")
  backupSchedulesUpdated      BackupSchedule[]     @relation("BackupScheduleUpdatedBy")
  backupDriveIntegrations     BackupDriveIntegration[] @relation("BackupDriveConnectedBy")
  backupStorageSettingsUpdated BackupStorageSettings[] @relation("BackupStorageSettingsUpdatedBy")

  @@map("users")
}

model BackupStorageSettings {
  id               String              @id @default("00000000-0000-4000-8000-0000000000d1") @db.Uuid
  defaultPolicy    BackupStoragePolicy @default(local_and_drive) @map("default_policy")
  updatedByUserId  String?             @map("updated_by_user_id") @db.Uuid
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  updatedBy User? @relation("BackupStorageSettingsUpdatedBy", fields: [updatedByUserId], references: [id])

  @@map("backup_storage_settings")
}

model BackupSchedule {
  id             String                  @id @default(uuid()) @db.Uuid
  enabled        Boolean                 @default(true)
  frequency      BackupScheduleFrequency
  hour           Int                     @db.SmallInt
  minute         Int                     @db.SmallInt
  retentionDays  Int                     @default(7) @map("retention_days")
  storagePolicy  BackupStoragePolicy?    @map("storage_policy")
  lastRunAt      DateTime?               @map("last_run_at") @db.Timestamptz(6)
  createdByUserId String                 @map("created_by_user_id") @db.Uuid
  updatedByUserId String                 @map("updated_by_user_id") @db.Uuid
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy User        @relation("BackupScheduleCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User        @relation("BackupScheduleUpdatedBy", fields: [updatedByUserId], references: [id])
  backupJobs  BackupJob[]

  @@index([enabled], map: "idx_backup_schedules_enabled")
  @@map("backup_schedules")
}

model BackupDriveIntegration {
  id                    String   @id @default(uuid()) @db.Uuid
  encryptedRefreshToken String   @map("encrypted_refresh_token") @db.Text
  encryptedFolderId     String   @map("encrypted_folder_id") @db.Text
  connectedByUserId     String   @map("connected_by_user_id") @db.Uuid
  connectedAt           DateTime @map("connected_at") @db.Timestamptz(6)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  connectedBy User @relation("BackupDriveConnectedBy", fields: [connectedByUserId], references: [id])

  @@map("backup_drive_integrations")
}

model BackupJob {
  id                String          @id @default(uuid()) @db.Uuid
  type              BackupJobType
  status            BackupJobStatus @default(pending)
  label             String?
  triggeredByUserId String          @map("triggered_by_user_id") @db.Uuid
  artifactPath      String?         @map("artifact_path")
  dumpFilename      String?         @map("dump_filename")
  manifest          Json?           @db.JsonB
  progressPercent   Int             @default(0) @map("progress_percent") @db.SmallInt
  bytesWritten      BigInt          @default(0) @map("bytes_written")
  errorMessage      String?         @map("error_message")
  parentJobId       String?         @map("parent_job_id") @db.Uuid
  backupScheduleId  String?         @map("backup_schedule_id") @db.Uuid
  storagePolicy      BackupStoragePolicy @default(local_and_drive) @map("storage_policy")
  storageDestination BackupStorageDestination @default(local) @map("storage_destination")
  localArtifactPurged Boolean        @default(false) @map("local_artifact_purged")
  gdriveFileId       String?         @map("gdrive_file_id")
  gdriveSyncedAt     DateTime?       @map("gdrive_synced_at") @db.Timestamptz(6)
  gdriveSyncStatus   BackupDriveSyncStatus? @map("gdrive_sync_status")
  gdriveSyncError    String?         @map("gdrive_sync_error")
  gdriveSyncAttempts Int             @default(0) @map("gdrive_sync_attempts")
  gdriveNextRetryAt  DateTime?       @map("gdrive_next_retry_at") @db.Timestamptz(6)
  startedAt         DateTime?       @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?       @map("completed_at") @db.Timestamptz(6)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  triggeredBy User      @relation("BackupTriggeredBy", fields: [triggeredByUserId], references: [id])
  parentJob      BackupJob?     @relation("BackupJobParent", fields: [parentJobId], references: [id], onDelete: SetNull)
  childJobs      BackupJob[]    @relation("BackupJobParent")
  backupSchedule BackupSchedule? @relation(fields: [backupScheduleId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)], map: "idx_backup_jobs_status_created")
  @@index([triggeredByUserId, createdAt(sort: Desc)], map: "idx_backup_jobs_triggered_by")
  @@index([parentJobId], map: "idx_backup_jobs_parent_job")
  @@index([backupScheduleId, createdAt(sort: Desc)], map: "idx_backup_jobs_schedule")
  @@map("backup_jobs")
}

/// Server-side refresh token family (Phase 6.5 replay protection).
model AuthRefreshSession {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  currentJti   String    @unique @map("current_jti") @db.Uuid
  tokenVersion Int       @map("token_version")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  rotatedAt    DateTime  @default(now()) @map("rotated_at") @db.Timestamptz(6)

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotations  AuthRefreshRotation[]

  @@index([userId])
  @@index([userId, revokedAt])
  @@map("auth_refresh_sessions")
}

/// Idempotent replay of parallel refresh with the same presented JTI.
model AuthRefreshRotation {
  sessionId String   @map("session_id") @db.Uuid
  fromJti   String   @map("from_jti") @db.Uuid
  toJti     String   @map("to_jti") @db.Uuid
  rotatedAt DateTime @default(now()) @map("rotated_at") @db.Timestamptz(6)

  session AuthRefreshSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([sessionId, fromJti])
  @@map("auth_refresh_rotations")
}

model Warehouse {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  code      String          @unique
  address   String?
  city      String?
  country   String          @default("SA")
  status    WarehouseStatus @default(active)
  workflowUxSettings Json?            @map("workflow_ux_settings") @db.JsonB
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)

  locations           Location[]
  currentStock        CurrentStock[]
  stockAdjustments      StockAdjustment[]
  cycleCountSchedules   CycleCountSchedule[]
  cycleCounts           CycleCount[]
  cycleCountVariances   CycleCountVariance[]
  cycleCountProductHistory CycleCountProductHistory[]
  workers               Worker[]
  workflowInstances     WorkflowInstance[]
  returnOrders            ReturnOrder[]

  @@map("warehouses")
}

model Location {
  id                 String         @id @default(uuid()) @db.Uuid
  warehouseId        String         @map("warehouse_id") @db.Uuid
  parentId           String?        @map("parent_id") @db.Uuid
  name               String
  fullPath           String         @map("full_path")
  type               LocationType   @default(internal)
  barcode            String         @unique
  sortOrder          Int            @default(0) @map("sort_order")
  status             LocationStatus @default(active)
  maxWeightKg        Decimal?       @map("max_weight_kg") @db.Decimal(10, 2)
  maxCbm             Decimal?       @map("max_cbm") @db.Decimal(10, 4)
  maxPalletPositions Int?           @map("max_pallet_positions")
  aisle              String?
  rack               String?
  bin                String?
  coordX             Decimal?       @map("coord_x") @db.Decimal(10, 3)
  coordY             Decimal?       @map("coord_y") @db.Decimal(10, 3)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)

  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  parent       Location?    @relation("LocationParent", fields: [parentId], references: [id])
  children     Location[]   @relation("LocationParent")
  currentStock           CurrentStock[]
  stockAdjustmentLines   StockAdjustmentLine[]
  cycleCountLines        CycleCountLine[]
  cycleCountVariances    CycleCountVariance[]
  packages               Package[]
  returnOrderLines       ReturnOrderLine[]

  @@index([warehouseId, parentId, sortOrder], map: "idx_locations_wh_parent_sort")
  @@map("locations")
}

model Product {
  id                 String              @id @default(uuid()) @db.Uuid
  companyId          String              @map("company_id") @db.Uuid
  categoryId         String?             @map("category_id") @db.Uuid
  name               String
  sku                String
  barcode            String?
  description        String?
  trackingType       ProductTrackingType @default(none) @map("tracking_type")
  uom                ProductUom          @default(piece)
  weightKg           Decimal?            @map("weight_kg") @db.Decimal(10, 4)
  volumeCbm          Decimal?            @map("volume_cbm") @db.Decimal(10, 6)
  lengthCm           Decimal?            @map("length_cm") @db.Decimal(8, 2)
  widthCm            Decimal?            @map("width_cm") @db.Decimal(8, 2)
  heightCm           Decimal?            @map("height_cm") @db.Decimal(8, 2)
  expiryTracking     Boolean             @default(false) @map("expiry_tracking")
  minStockThreshold  Int                 @default(0) @map("min_stock_threshold")
  status             ProductStatus       @default(active)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)

  company           Company            @relation(fields: [companyId], references: [id])
  lots              Lot[]
  currentStock      CurrentStock[]
  inboundLines         InboundOrderLine[]
  outboundLines        OutboundOrderLine[]
  returnOrderLines     ReturnOrderLine[]
  packages             Package[]
  ledgerEntries        InventoryLedger[]
  stockAdjustmentLines       StockAdjustmentLine[]
  cycleCountLines            CycleCountLine[]
  cycleCountVariances        CycleCountVariance[]
  cycleCountProductHistory   CycleCountProductHistory[]

  @@unique([companyId, sku], map: "uq_product_sku_per_company")
  @@map("products")
}

model Lot {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  lotNumber       String   @map("lot_number")
  expiryDate      DateTime? @map("expiry_date") @db.Date
  manufactureDate DateTime? @map("manufacture_date") @db.Date
  receivedAt      DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product       Product        @relation(fields: [productId], references: [id])
  currentStock  CurrentStock[]
  ledgerEntries          InventoryLedger[]
  stockAdjustmentLines   StockAdjustmentLine[]
  cycleCountLines        CycleCountLine[]
  cycleCountVariances    CycleCountVariance[]
  returnOrderLines       ReturnOrderLine[]
  packages               Package[]

  @@unique([productId, lotNumber], map: "uq_lot_per_product")
  @@map("lots")
}

model CurrentStock {
  id                String      @id @default(uuid()) @db.Uuid
  companyId         String      @map("company_id") @db.Uuid
  productId         String      @map("product_id") @db.Uuid
  locationId        String      @map("location_id") @db.Uuid
  warehouseId       String      @map("warehouse_id") @db.Uuid
  lotId             String?     @map("lot_id") @db.Uuid
  packageId         String?     @map("package_id") @db.Uuid
  quantityOnHand    Decimal     @default(0) @map("quantity_on_hand") @db.Decimal(15, 4)
  quantityReserved  Decimal     @default(0) @map("quantity_reserved") @db.Decimal(15, 4)
  /// Generated column in PostgreSQL: quantityOnHand - quantityReserved
  quantityAvailable Decimal     @map("quantity_available") @db.Decimal(15, 4)
  status            StockStatus @default(available)
  version           Int         @default(0)
  lastMovementAt    DateTime?   @map("last_movement_at") @db.Timestamptz(6)

  company   Company   @relation(fields: [companyId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  location  Location  @relation(fields: [locationId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  lot       Lot?      @relation(fields: [lotId], references: [id])

  @@map("current_stock")
}

/// `inventory_ledger` is partitioned by month in PostgreSQL. Prisma sees it as
/// a regular table — partitioning is transparent. The composite primary key
/// (id, created_at) is required by Postgres for partitioning but Prisma still
/// only needs `id` to address rows.
model InventoryLedger {
  id              String        @default(uuid()) @db.Uuid
  companyId       String        @map("company_id") @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  lotId           String?       @map("lot_id") @db.Uuid
  packageId       String?       @map("package_id") @db.Uuid
  fromLocationId  String?       @map("from_location_id") @db.Uuid
  toLocationId    String?       @map("to_location_id") @db.Uuid
  movementType    MovementType  @map("movement_type")
  quantity        Decimal       @db.Decimal(15, 4)
  quantityBefore  Decimal?      @map("quantity_before") @db.Decimal(15, 4)
  quantityAfter   Decimal?      @map("quantity_after") @db.Decimal(15, 4)
  referenceType   LedgerRefType @map("reference_type")
  referenceId     String        @map("reference_id") @db.Uuid
  operatorId      String        @map("operator_id") @db.Uuid
  idempotencyKey  String?       @map("idempotency_key")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  company  Company @relation(fields: [companyId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  lot      Lot?    @relation(fields: [lotId], references: [id])
  operator User    @relation(fields: [operatorId], references: [id])

  @@id([id, createdAt])
  @@map("inventory_ledger")
}

model StockAdjustment {
  id            String           @id @default(uuid()) @db.Uuid
  companyId     String           @map("company_id") @db.Uuid
  warehouseId   String           @map("warehouse_id") @db.Uuid
  cycleCountId  String?          @map("cycle_count_id") @db.Uuid
  reason        String
  status        AdjustmentStatus @default(draft)
  approvedBy    String?          @map("approved_by") @db.Uuid
  approvedAt    DateTime?        @map("approved_at") @db.Timestamptz(6)
  createdBy     String           @map("created_by") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)

  company    Company              @relation(fields: [companyId], references: [id])
  warehouse  Warehouse            @relation(fields: [warehouseId], references: [id])
  cycleCount CycleCount?          @relation(fields: [cycleCountId], references: [id])
  creator    User                 @relation("AdjustmentCreatedBy", fields: [createdBy], references: [id])
  approver   User?                @relation("AdjustmentApprovedBy", fields: [approvedBy], references: [id])
  lines      StockAdjustmentLine[]
  variances  CycleCountVariance[]

  @@index([cycleCountId])
  @@map("stock_adjustments")
}

model StockAdjustmentLine {
  id                   String   @id @default(uuid()) @db.Uuid
  adjustmentId         String   @map("adjustment_id") @db.Uuid
  productId            String   @map("product_id") @db.Uuid
  locationId           String   @map("location_id") @db.Uuid
  lotId                String?  @map("lot_id") @db.Uuid
  quantityBefore       Decimal  @map("quantity_before") @db.Decimal(15, 4)
  quantityAfter        Decimal  @map("quantity_after") @db.Decimal(15, 4)
  reasonNote           String?  @map("reason_note")
  cycleCountVarianceId String?  @unique @map("cycle_count_variance_id") @db.Uuid

  adjustment         StockAdjustment      @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product            Product              @relation(fields: [productId], references: [id])
  location           Location             @relation(fields: [locationId], references: [id])
  lot                Lot?                 @relation(fields: [lotId], references: [id])
  cycleCountVariance CycleCountVariance?  @relation(fields: [cycleCountVarianceId], references: [id])

  @@map("stock_adjustment_lines")
}

// ---------------------------------------------------------------------------
// CYCLE COUNT (Phase 7.1)
// ---------------------------------------------------------------------------

/// Warehouse admin recurrence config — one row per company + warehouse.
model CycleCountSchedule {
  id                 String   @id @default(uuid()) @db.Uuid
  companyId          String   @map("company_id") @db.Uuid
  warehouseId        String   @map("warehouse_id") @db.Uuid
  intervalDays       Int      @map("interval_days")
  enabled            Boolean  @default(true)
  includeZeroOnHand  Boolean  @default(false) @map("include_zero_on_hand")
  lastRunAt          DateTime? @map("last_run_at") @db.Timestamptz(6)
  nextRunAt          DateTime? @map("next_run_at") @db.Timestamptz(6)
  createdBy          String   @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  company   Company   @relation(fields: [companyId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  creator   User      @relation("CycleCountScheduleCreator", fields: [createdBy], references: [id])
  counts    CycleCount[]

  @@unique([companyId, warehouseId], map: "cycle_count_schedules_company_warehouse_uidx")
  @@index([enabled, nextRunAt], map: "idx_cycle_count_schedules_due")
  @@map("cycle_count_schedules")
}

/// Operational count session (header). Inventory is not mutated on complete in Phase 7.1.
model CycleCount {
  id               String           @id @default(uuid()) @db.Uuid
  scheduleId       String?          @map("schedule_id") @db.Uuid
  companyId        String           @map("company_id") @db.Uuid
  warehouseId      String           @map("warehouse_id") @db.Uuid
  status           CycleCountStatus @default(scheduled)
  source           CycleCountSource
  snapshotAt         DateTime?        @map("snapshot_at") @db.Timestamptz(6)
  blindCount         Boolean          @default(true) @map("blind_count")
  assignedWorkerId   String?          @map("assigned_worker_id") @db.Uuid
  executingWorkerId  String?          @map("executing_worker_id") @db.Uuid
  createdBy          String           @map("created_by") @db.Uuid
  startedAt        DateTime?        @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime?        @map("completed_at") @db.Timestamptz(6)
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)

  company        Company             @relation(fields: [companyId], references: [id])
  warehouse      Warehouse           @relation(fields: [warehouseId], references: [id])
  schedule       CycleCountSchedule? @relation(fields: [scheduleId], references: [id])
  assignedWorker  Worker?             @relation("CycleCountSessionAssignee", fields: [assignedWorkerId], references: [id])
  executingWorker Worker?             @relation("CycleCountExecutingWorker", fields: [executingWorkerId], references: [id])
  creator         User                @relation("CycleCountCreator", fields: [createdBy], references: [id])
  lines           CycleCountLine[]
  variances       CycleCountVariance[]
  stockAdjustments StockAdjustment[]

  @@index([companyId, warehouseId, status], map: "idx_cycle_counts_company_wh_status")
  @@index([assignedWorkerId, status], map: "idx_cycle_counts_worker_status")
  @@index([executingWorkerId], map: "idx_cycle_counts_executing_worker")
  @@index([scheduleId])
  @@map("cycle_counts")
}

/// Per location / lot grain — expected qty frozen at snapshot time.
model CycleCountLine {
  id                  String               @id @default(uuid()) @db.Uuid
  cycleCountId        String               @map("cycle_count_id") @db.Uuid
  productId           String               @map("product_id") @db.Uuid
  locationId          String               @map("location_id") @db.Uuid
  lotId               String?              @map("lot_id") @db.Uuid
  expectedQuantity    Decimal              @map("expected_quantity") @db.Decimal(15, 4)
  actualQuantity      Decimal?             @map("actual_quantity") @db.Decimal(15, 4)
  discrepancyQuantity Decimal?             @map("discrepancy_quantity") @db.Decimal(15, 4)
  status              CycleCountLineStatus @default(pending)
  assignedWorkerId    String?              @map("assigned_worker_id") @db.Uuid
  countedBy           String?              @map("counted_by") @db.Uuid
  countedAt           DateTime?            @map("counted_at") @db.Timestamptz(6)
  countNotes          String?              @map("count_notes")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  cycleCount     CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [productId], references: [id])
  location       Location   @relation(fields: [locationId], references: [id])
  lot            Lot?       @relation(fields: [lotId], references: [id])
  assignedWorker Worker?    @relation("CycleCountLineAssignee", fields: [assignedWorkerId], references: [id])
  counter        User?      @relation("CycleCountLineCounter", fields: [countedBy], references: [id])
  variance       CycleCountVariance?

  @@index([cycleCountId])
  @@index([productId])
  @@index([assignedWorkerId, status], map: "idx_cycle_count_lines_worker_status")
  @@map("cycle_count_lines")
}

/// Inventory discrepancy from a counted cycle count line — review before adjustment.
model CycleCountVariance {
  id                   String                   @id @default(uuid()) @db.Uuid
  cycleCountId         String                   @map("cycle_count_id") @db.Uuid
  cycleCountLineId     String                   @unique @map("cycle_count_line_id") @db.Uuid
  companyId            String                   @map("company_id") @db.Uuid
  warehouseId          String                   @map("warehouse_id") @db.Uuid
  productId            String                   @map("product_id") @db.Uuid
  locationId           String                   @map("location_id") @db.Uuid
  lotId                String?                  @map("lot_id") @db.Uuid
  expectedQuantity     Decimal                  @map("expected_quantity") @db.Decimal(15, 4)
  actualQuantity       Decimal                  @map("actual_quantity") @db.Decimal(15, 4)
  discrepancyQuantity  Decimal                  @map("discrepancy_quantity") @db.Decimal(15, 4)
  reasonCode           VarianceReasonCode?      @map("reason_code")
  status               CycleCountVarianceStatus @default(pending_review)
  reviewNotes          String?                  @map("review_notes")
  reviewedBy           String?                  @map("reviewed_by") @db.Uuid
  reviewedAt           DateTime?                @map("reviewed_at") @db.Timestamptz(6)
  stockAdjustmentId    String?                  @map("stock_adjustment_id") @db.Uuid
  postedAt             DateTime?                @map("posted_at") @db.Timestamptz(6)
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)

  cycleCount          CycleCount            @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  cycleCountLine      CycleCountLine        @relation(fields: [cycleCountLineId], references: [id], onDelete: Cascade)
  company             Company               @relation(fields: [companyId], references: [id])
  warehouse           Warehouse             @relation(fields: [warehouseId], references: [id])
  product             Product               @relation(fields: [productId], references: [id])
  location            Location              @relation(fields: [locationId], references: [id])
  lot                 Lot?                  @relation(fields: [lotId], references: [id])
  reviewer            User?                 @relation("CycleCountVarianceReviewer", fields: [reviewedBy], references: [id])
  stockAdjustment     StockAdjustment?      @relation(fields: [stockAdjustmentId], references: [id])
  adjustmentLine      StockAdjustmentLine?

  @@index([cycleCountId, status], map: "idx_cycle_count_variances_count_status")
  @@index([companyId, status], map: "idx_cycle_count_variances_company_status")
  @@map("cycle_count_variances")
}

/// Product-level last count + next due for recurrence (updated when a count completes).
model CycleCountProductHistory {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  warehouseId     String    @map("warehouse_id") @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  lastCountedAt   DateTime  @map("last_counted_at") @db.Timestamptz(6)
  lastCycleCountId String?  @map("last_cycle_count_id") @db.Uuid
  nextDueAt       DateTime? @map("next_due_at") @db.Timestamptz(6)
  completionCount Int       @default(1) @map("completion_count")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  company   Company   @relation(fields: [companyId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([companyId, warehouseId, productId], map: "cycle_count_product_history_uidx")
  @@index([companyId, warehouseId, nextDueAt], map: "idx_cycle_count_product_history_due")
  @@map("cycle_count_product_history")
}

// ---------------------------------------------------------------------------
// INBOUND
// ---------------------------------------------------------------------------

model InboundOrder {
  id                  String             @id @default(uuid()) @db.Uuid
  companyId           String             @map("company_id") @db.Uuid
  /// DEFAULT '' — populated by trigger fn_inbound_order_number on INSERT
  orderNumber         String             @unique @default("") @map("order_number")
  status              InboundOrderStatus @default(draft)
  expectedArrivalDate DateTime           @map("expected_arrival_date") @db.Date
  clientReference     String?            @map("client_reference")
  notes               String?
  confirmedAt         DateTime?          @map("confirmed_at") @db.Timestamptz(6)
  completedAt         DateTime?          @map("completed_at") @db.Timestamptz(6)
  cancelledAt         DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy         String?            @map("cancelled_by") @db.Uuid
  createdBy           String             @map("created_by") @db.Uuid
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  company Company            @relation(fields: [companyId], references: [id])
  creator User               @relation("InboundCreatedBy", fields: [createdBy], references: [id])
  lines   InboundOrderLine[]

  @@map("inbound_orders")
}

model InboundOrderLine {
  id                  String          @id @default(uuid()) @db.Uuid
  inboundOrderId      String          @map("inbound_order_id") @db.Uuid
  productId           String          @map("product_id") @db.Uuid
  expectedQuantity    Decimal         @map("expected_quantity") @db.Decimal(15, 4)
  receivedQuantity    Decimal         @default(0) @map("received_quantity") @db.Decimal(15, 4)
  expectedLotNumber   String?         @map("expected_lot_number")
  expectedExpiryDate  DateTime?       @map("expected_expiry_date") @db.Date
  discrepancyType     DiscrepancyType @default(none) @map("discrepancy_type")
  discrepancyNotes    String?         @map("discrepancy_notes")
  qcStatus            InboundQcStatus @default(not_required) @map("qc_status")
  lineNumber          Int             @map("line_number")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)

  order   InboundOrder @relation(fields: [inboundOrderId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@map("inbound_order_lines")
}

// ---------------------------------------------------------------------------
// OUTBOUND
// ---------------------------------------------------------------------------

model OutboundOrder {
  id                 String              @id @default(uuid()) @db.Uuid
  companyId          String              @map("company_id") @db.Uuid
  /// DEFAULT '' — populated by trigger fn_outbound_order_number on INSERT
  orderNumber        String              @unique @default("") @map("order_number")
  status             OutboundOrderStatus @default(draft)
  destinationAddress String              @map("destination_address")
  requiredShipDate   DateTime            @map("required_ship_date") @db.Date
  carrier            String?
  trackingNumber     String?             @map("tracking_number")
  clientReference    String?             @map("client_reference")
  notes              String?
  requiresPacking    Boolean             @default(true) @map("requires_packing")
  confirmedAt        DateTime?           @map("confirmed_at") @db.Timestamptz(6)
  pickingStartedAt   DateTime?           @map("picking_started_at") @db.Timestamptz(6)
  shippedAt          DateTime?           @map("shipped_at") @db.Timestamptz(6)
  cancelledAt        DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy        String?             @map("cancelled_by") @db.Uuid
  createdBy          String              @map("created_by") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)

  company      Company             @relation(fields: [companyId], references: [id])
  creator      User                @relation("OutboundCreatedBy", fields: [createdBy], references: [id])
  lines        OutboundOrderLine[]
  returnOrders ReturnOrder[]

  @@map("outbound_orders")
}

model OutboundOrderLine {
  id                 String             @id @default(uuid()) @db.Uuid
  outboundOrderId    String             @map("outbound_order_id") @db.Uuid
  productId          String             @map("product_id") @db.Uuid
  requestedQuantity  Decimal            @map("requested_quantity") @db.Decimal(15, 4)
  pickedQuantity     Decimal            @default(0) @map("picked_quantity") @db.Decimal(15, 4)
  specificLotId      String?            @map("specific_lot_id") @db.Uuid
  status             OutboundLineStatus @default(pending)
  lineNumber         Int                @map("line_number")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  order              OutboundOrder      @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  product            Product            @relation(fields: [productId], references: [id])
  returnOrderLines   ReturnOrderLine[]

  @@map("outbound_order_lines")
}

// ---------------------------------------------------------------------------
// RETURNS
// ---------------------------------------------------------------------------

model Package {
  id          String        @id @default(uuid()) @db.Uuid
  productId   String        @map("product_id") @db.Uuid
  lotId       String?       @map("lot_id") @db.Uuid
  locationId  String?       @map("location_id") @db.Uuid
  packageCode String        @unique @map("package_code")
  status      PackageStatus @default(in_warehouse)
  receivedAt  DateTime      @default(now()) @map("received_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  product            Product           @relation(fields: [productId], references: [id])
  lot                Lot?              @relation(fields: [lotId], references: [id])
  location           Location?         @relation(fields: [locationId], references: [id])
  returnOrders       ReturnOrder[]
  returnOrderLines   ReturnOrderLine[]

  @@index([productId], map: "idx_packages_product")
  @@map("packages")
}

model ReturnOrder {
  id                      String            @id @default(uuid()) @db.Uuid
  companyId               String            @map("company_id") @db.Uuid
  warehouseId             String?           @map("warehouse_id") @db.Uuid
  /// DEFAULT '' — populated by trigger fn_return_order_number on INSERT
  orderNumber             String            @unique @default("") @map("order_number")
  originalOutboundOrderId String?           @map("original_outbound_order_id") @db.Uuid
  packageId               String?           @map("package_id") @db.Uuid
  shipmentReference       String?           @map("shipment_reference")
  clientReference         String?           @map("client_reference")
  status                  ReturnOrderStatus @default(draft)
  notes                   String?
  confirmedAt             DateTime?         @map("confirmed_at") @db.Timestamptz(6)
  receivingStartedAt      DateTime?         @map("receiving_started_at") @db.Timestamptz(6)
  inspectingStartedAt     DateTime?         @map("inspecting_started_at") @db.Timestamptz(6)
  completedAt             DateTime?         @map("completed_at") @db.Timestamptz(6)
  cancelledAt             DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy             String?           @map("cancelled_by") @db.Uuid
  createdBy               String            @map("created_by") @db.Uuid
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  company          Company        @relation(fields: [companyId], references: [id])
  warehouse        Warehouse?     @relation(fields: [warehouseId], references: [id])
  creator          User           @relation("ReturnCreatedBy", fields: [createdBy], references: [id])
  canceller        User?          @relation("ReturnCancelledBy", fields: [cancelledBy], references: [id])
  originalOutbound OutboundOrder? @relation(fields: [originalOutboundOrderId], references: [id])
  package          Package?       @relation(fields: [packageId], references: [id])
  lines            ReturnOrderLine[]

  @@index([companyId], map: "idx_return_orders_company")
  @@map("return_orders")
}

model ReturnOrderLine {
  id                   String                 @id @default(uuid()) @db.Uuid
  returnOrderId        String                 @map("return_order_id") @db.Uuid
  productId            String                 @map("product_id") @db.Uuid
  outboundOrderLineId  String?                @map("outbound_order_line_id") @db.Uuid
  packageId            String?                @map("package_id") @db.Uuid
  lotId                String?                @map("lot_id") @db.Uuid
  expectedQuantity     Decimal                @map("expected_quantity") @db.Decimal(15, 4)
  receivedQuantity     Decimal                @default(0) @map("received_quantity") @db.Decimal(15, 4)
  postedQuantity       Decimal                @default(0) @map("posted_quantity") @db.Decimal(15, 4)
  lineStatus           ReturnLineStatus       @default(pending) @map("line_status")
  condition            ReturnItemCondition?
  disposition          ReturnItemDisposition?
  targetLocationId     String?                @map("target_location_id") @db.Uuid
  inspectionNotes      String?                @map("inspection_notes")
  inspectedAt          DateTime?              @map("inspected_at") @db.Timestamptz(6)
  inspectedBy          String?                @map("inspected_by") @db.Uuid
  postedAt             DateTime?              @map("posted_at") @db.Timestamptz(6)
  lineNumber           Int                    @default(1) @map("line_number")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)

  returnOrder       ReturnOrder        @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id])
  outboundOrderLine OutboundOrderLine? @relation(fields: [outboundOrderLineId], references: [id])
  package           Package?           @relation(fields: [packageId], references: [id])
  lot               Lot?               @relation(fields: [lotId], references: [id])
  targetLocation    Location?          @relation(fields: [targetLocationId], references: [id])
  inspector         User?              @relation("ReturnLineInspector", fields: [inspectedBy], references: [id])

  @@index([returnOrderId], map: "idx_return_lines")
  @@index([returnOrderId, lineStatus], map: "idx_return_lines_status")
  @@map("return_order_lines")
}

// ---------------------------------------------------------------------------
// WORKFLOW — TASK ENGINE (additive; does not alter ledger partitioning)
// ---------------------------------------------------------------------------

model LedgerIdempotency {
  /// Deterministic ledger write key; duplicate inserts short-circuit to prior row.
  idempotencyKey String   @id @map("idempotency_key") @db.VarChar(512)
  /// `inventory_ledger.id` UUID (composite PK `(id, created_at)` unchanged in DB).
  ledgerId String @map("ledger_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("ledger_idempotency")
}

model Worker {
  id          String                   @id @default(uuid()) @db.Uuid
  companyId   String                   @map("company_id") @db.Uuid
  warehouseId String?                  @map("warehouse_id") @db.Uuid
  displayName String                   @map("display_name")
  userId      String?                  @unique @map("user_id") @db.Uuid
  status      WorkerOperationalStatus  @default(active)
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)

  company         Company               @relation(fields: [companyId], references: [id])
  warehouse       Warehouse?            @relation(fields: [warehouseId], references: [id])
  user            User?                 @relation(fields: [userId], references: [id])
  roles           WorkerRoleAssignment[]
  taskAssignments          TaskAssignment[]
  skills                   WorkerSkill[]
  cycleCountsAssigned      CycleCount[]     @relation("CycleCountSessionAssignee")
  cycleCountsExecuting     CycleCount[]     @relation("CycleCountExecutingWorker")
  cycleCountLinesAssigned  CycleCountLine[] @relation("CycleCountLineAssignee")

  @@index([companyId])
  @@index([warehouseId])
  @@map("workers")
}

model WorkerRoleAssignment {
  workerId String                @map("worker_id") @db.Uuid
  role     WorkerOperationalRole

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@id([workerId, role])
  @@map("worker_role_assignments")
}

model WorkerSkill {
  id             String    @id @default(uuid()) @db.Uuid
  workerId       String    @map("worker_id") @db.Uuid
  skillCode      String    @map("skill_code")
  proficiency    Int       @default(1)
  certifiedUntil DateTime? @map("certified_until") @db.Timestamptz(6)

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, skillCode])
  @@map("worker_skills")
}

model WarehouseTaskRequiredSkill {
  taskId            String @map("task_id") @db.Uuid
  skillCode         String @map("skill_code")
  minimumProficiency Int    @default(1) @map("minimum_proficiency")

  task WarehouseTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, skillCode])
  @@map("warehouse_task_required_skills")
}

model WorkflowInstance {
  id             String                   @id @default(uuid()) @db.Uuid
  companyId      String                   @map("company_id") @db.Uuid
  warehouseId    String                   @map("warehouse_id") @db.Uuid
  referenceType  WorkflowReferenceType    @map("reference_type")
  referenceId    String                   @map("reference_id") @db.Uuid
  definitionCode String                   @map("definition_code")
  status         WorkflowInstanceStatus   @default(pending)
  metadata       Json?                    @db.JsonB
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)

  company   Company         @relation(fields: [companyId], references: [id])
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  nodes     WorkflowNode[]
  tasks     WarehouseTask[]

  @@index([companyId])
  @@index([referenceType, referenceId])
  @@index([warehouseId, companyId], map: "idx_workflow_instances_wh_company")
  // Partial unique (migration 20260629140000): workflow_instances_one_active_per_reference_uidx
  // — one row per reference while status ∈ pending | in_progress | degraded
  @@map("workflow_instances")
}

model WorkflowNode {
  id          String               @id @default(uuid()) @db.Uuid
  instanceId  String               @map("instance_id") @db.Uuid
  stepKind    WorkflowStepKind     @map("step_kind")
  status      WorkflowNodeStatus   @default(pending)
  sequence    Int
  parentNodeId String?             @map("parent_node_id") @db.Uuid
  metadata    Json?                @db.JsonB
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)

  instance   WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  parent     WorkflowNode?     @relation("WorkflowNodeHierarchy", fields: [parentNodeId], references: [id])
  children   WorkflowNode[]    @relation("WorkflowNodeHierarchy")
  tasks      WarehouseTask[]

  @@index([instanceId])
  @@map("workflow_nodes")
}

model WarehouseTask {
  id                     String               @id @default(uuid()) @db.Uuid
  workflowInstanceId     String               @map("workflow_instance_id") @db.Uuid
  workflowNodeId        String?              @map("workflow_node_id") @db.Uuid
  taskType              WarehouseTaskType    @map("task_type")
  status                WarehouseTaskStatus  @default(pending)
  priority              Int                  @default(0)
  dueAt                 DateTime?            @map("due_at") @db.Timestamptz(6)
  payload               Json                 @db.JsonB
  payloadSchemaVersion  Int                  @default(1) @map("payload_schema_version")
  lockVersion           Int                  @default(0) @map("lock_version")
  correlationId        String?              @map("correlation_id")
  leaseExpiresAt        DateTime?            @map("lease_expires_at") @db.Timestamptz(6)
  slaMinutes            Int?                  @map("sla_minutes")
  escalationLevel       Int                  @default(0) @map("escalation_level")
  startedAt             DateTime?           @map("started_at") @db.Timestamptz(6)
  completedAt           DateTime?            @map("completed_at") @db.Timestamptz(6)
  completedById         String?              @map("completed_by") @db.Uuid
  failureReason         String?             @map("failure_reason")
  executionState       Json?                @map("execution_state") @db.JsonB
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workflowInstance WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  workflowNode    WorkflowNode?    @relation(fields: [workflowNodeId], references: [id])
  assignments     TaskAssignment[]
  events           TaskEvent[]
  requiredSkills  WarehouseTaskRequiredSkill[]
  completedBy     User?            @relation("WarehouseTaskCompleter", fields: [completedById], references: [id])

  @@index([workflowInstanceId])
  @@index([status, taskType])
  @@index([updatedAt(sort: Desc)], map: "idx_warehouse_tasks_updated_at_desc")
  @@index([status, updatedAt(sort: Desc)], map: "idx_warehouse_tasks_status_updated_at_desc")
  @@map("warehouse_tasks")
}

model TaskAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  taskId       String    @map("task_id") @db.Uuid
  workerId     String    @map("worker_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedById String?   @map("assigned_by") @db.Uuid
  unassignedAt DateTime? @map("unassigned_at") @db.Timestamptz(6)

  task       WarehouseTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  worker     Worker       @relation(fields: [workerId], references: [id])
  assignedBy User?        @relation("TaskAssignedBy", fields: [assignedById], references: [id])

  @@index([workerId])
  @@index([taskId])
  @@map("task_assignments")
}

model TaskEvent {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  event     String
  actorId   String?  @map("actor_id") @db.Uuid
  payload   Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  task WarehouseTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User?        @relation("TaskEventActor", fields: [actorId], references: [id])

  @@index([taskId])
  @@map("task_events")
}

model Notification {
  id            String              @id @default(uuid()) @db.Uuid
  companyId     String?             @map("company_id") @db.Uuid
  userId        String?             @map("user_id") @db.Uuid
  type          String
  title         String
  body          String
  referenceType String?             @map("reference_type")
  referenceId   String?             @map("reference_id") @db.Uuid
  channel       NotificationChannel @default(in_app)
  isRead        Boolean             @default(false) @map("is_read")
  readAt        DateTime?           @map("read_at") @db.Timestamptz(6)
  emailSent     Boolean             @default(false) @map("email_sent")
  emailSentAt   DateTime?           @map("email_sent_at") @db.Timestamptz(6)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([userId, isRead], map: "idx_notifications_user")
  @@index([companyId, isRead], map: "idx_notifications_company")
  @@map("notifications")
}
