# PostgreSQL — must be a SUPERUSER (or BYPASSRLS) for Phase 1 since improved_schema.sql
# turns FORCE ROW LEVEL SECURITY on. Phase 2 introduces a real RLS context middleware.
# Local Postgres (create DB `wms_db` if missing: `createdb -U postgres wms_db`)
DATABASE_URL=postgresql://postgres:nadim2003@localhost:5432/wms_db?schema=public

# Backend HTTP port
PORT=3000

# CORS — comma-separated list of allowed origins (Vite dev server default below).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Mock auth: defaults applied when X-User-Id / X-Company-Id headers are absent.
# These UUIDs are also created by `npm run db:seed` (deterministic seed values).
MOCK_USER_ID=00000000-0000-4000-8000-0000000000aa
MOCK_COMPANY_ID=00000000-0000-4000-8000-000000000001

# PostgreSQL admin (matches DATABASE_URL — used by some local setup scripts)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=nadim2003
DB_HOST=localhost
DB_PORT=5432
