# PostgreSQL — must be a SUPERUSER (or BYPASSRLS) for Phase 1 since improved_schema.sql
# turns FORCE ROW LEVEL SECURITY on. Phase 2 introduces a real RLS context middleware.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wms_db?schema=public

# Backend HTTP port
PORT=3000

# CORS — comma-separated list of allowed origins (Vite dev server default below).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Trusted external landing-page origins allowed to POST the public lead form (/api/forms/submit).
# Comma-separated. Leave empty if no external landing pages submit leads.
LANDING_FORM_CORS_ORIGINS=https://emdadsy.com,https://www.emdadsy.com

# JWT auth (required for all API routes except `POST /auth/login` and `POST /auth/logout`).
# Use a long random secret in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Access token lifetime (e.g. `8h`, `3600`, `15m`, `7d`).
JWT_EXPIRES_IN=8h

# Client portal (`/api/client/auth/*`) — use a distinct secret in production so internal JWTs never validate as client.
# Defaults to JWT_SECRET if unset (dev only).
CLIENT_JWT_SECRET=
CLIENT_JWT_EXPIRES_IN=8h

# Optional: default tenant header for dev when not embedded in the JWT (still send `X-Company-Id`).
# Seed company id (Acme Imports):
MOCK_COMPANY_ID=00000000-0000-4000-8000-000000000001

# Task workflow — when true, receiveLine only updates line qty (dock types: input/transit/iss); stock posts on putaway task.
TASK_WORKFLOW_INBOUND_RECEIVE_DEFERS_PUTAWAY=false
# When true, outbound confirm skips stock deduction; ledger posts when dispatch warehouse task completes.
TASK_WORKFLOW_OUTBOUND_CONFIRM_DEFERS_DEDUCTION=false

# Unified cutover (DEFAULT ON when unset): order confirm boots warehouse workflows (receive→qc→putaway; pick→pack→dispatch);
# disables inbound line receive API and outbound atomic deduct-from-confirm.
# Set to false / 0 / no / off for legacy flows only.
# TASK_ONLY_FLOWS=false

# Redis (optional; REDIS_ENABLED=false disables client for dev without Redis)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_KEY_PREFIX=wms:

# When true with Redis enabled, hydrates GET /tasks/:id from a short TTL read-through cache (invalidated on task/workflow writes).
TASK_READ_CACHE=false
TASK_READ_CACHE_TTL_SEC=45

# Socket.IO (`/realtime`) uses the same HTTP server. For horizontal scale, add `@socket.io/redis-adapter`
# and wire it in `main.ts` to the Redis instance above (see NestJS + Socket.IO clustering docs).

# Operational health / diagnostics (Phase 6.4)
# Liveness/readiness default on. In production, readiness returns check statuses only unless OPS_READY_VERBOSE=true.
# Set OPS_PROBE_SECRET (min 16 chars) in production to require X-Ops-Probe-Key on GET /api/ops/health/ready.
# OPS_DIAGNOSTICS_ENABLED defaults to false in production (internal-admin JWT when enabled).
# OPS_LIVENESS_ENABLED=true
# OPS_READINESS_ENABLED=true
# OPS_READY_VERBOSE=false
# OPS_DIAGNOSTICS_ENABLED=
# OPS_PROBE_SECRET=

# Audit log security & retention (Phase 5.3)
AUDIT_RETENTION_DAYS=730
AUDIT_QUERY_MAX_LIMIT=100
AUDIT_QUERY_MAX_OFFSET=5000
AUDIT_QUERY_MAX_DATE_RANGE_DAYS=366
AUDIT_QUERY_DEFAULT_WINDOW_DAYS=30
AUDIT_QUERY_COUNT_CAP=10000
AUDIT_EXPORT_MAX_ROWS=500
AUDIT_EXPORT_MAX_DATE_RANGE_DAYS=90
AUDIT_EXPORT_ENABLED=true

# Manual backup engine (BACKUP-2)
BACKUP_ENABLED=true
BACKUP_STORAGE_PATH=/var/lib/emdad-wms/backups/staging
BACKUP_ENV_ID=staging
# BACKUP_SIGNING_SECRET=          # min 16 chars; defaults to JWT_SECRET in dev
BACKUP_DOWNLOAD_TOKEN_TTL_SEC=300
BACKUP_MANUAL_COOLDOWN_SEC=900
# BACKUP_PG_DUMP_PATH=pg_dump
# BACKUP_PG_RESTORE_PATH=pg_restore
BACKUP_MAX_UPLOAD_BYTES=10737418240
BACKUP_PRE_SNAPSHOT_REQUIRED=true
FACTORY_RESET_ENABLED=false
BACKUP_SCHEDULER_ENABLED=true
# Retention cleanup (BACKUP-4B) — keep_last_* counts per bucket; cron + POST /backups/retention/cleanup
BACKUP_RETENTION_CLEANUP_ENABLED=true
BACKUP_KEEP_LAST_DAILY=7
BACKUP_KEEP_LAST_WEEKLY=4
BACKUP_KEEP_LAST_MONTHLY=12
BACKUP_PRE_SNAPSHOT_PROTECT_DAYS=7
# Backup health monitoring (BACKUP-4C)
BACKUP_HEALTH_MONITORING_ENABLED=true
BACKUP_HEALTH_MAX_SUCCESS_AGE_HOURS=48
BACKUP_HEALTH_WARN_SUCCESS_AGE_HOURS=24
BACKUP_HEALTH_STORAGE_WARN_BYTES=53687091200
BACKUP_HEALTH_STORAGE_CRITICAL_BYTES=85899345920
BACKUP_HEALTH_FAILURE_WINDOW_HOURS=24
BACKUP_HEALTH_FAILURE_WARN_COUNT=2
BACKUP_HEALTH_FAILURE_CRITICAL_COUNT=3
BACKUP_HEALTH_ALERT_COOLDOWN_HOURS=6

# Google Drive off-site backup (BACKUP-6A) — disabled by default
BACKUP_GDRIVE_ENABLED=false
# BACKUP_GDRIVE_CLIENT_ID=
# BACKUP_GDRIVE_CLIENT_SECRET=
# BACKUP_GDRIVE_REDIRECT_URI=https://staging-admin.emdadsy.com/api/integrations/google-drive/callback
# BACKUP_GDRIVE_ROOT_FOLDER_NAME=EMDAD WMS Backups
# BACKUP_GDRIVE_CONNECT_SUCCESS_URL=https://staging-admin.emdadsy.com/settings/backups/google-drive
# 32-byte AES key, base64-encoded (openssl rand -base64 32)
# BACKUP_ENCRYPTION_KEY=

# Certification only — forces Drive upload failure to validate retry scheduling
# BACKUP_GDRIVE_SIMULATE_UPLOAD_FAILURE=false

# When BACKUP_GDRIVE_ENABLED=true, startup validates OAuth credentials.
# Defaults to strict in production; set false to allow boot while credentials are being provisioned.
# BACKUP_GDRIVE_STARTUP_STRICT=false

# Storage routing & sync policies (BACKUP-6B)
# local_only | drive_only | local_and_drive
BACKUP_DEFAULT_STORAGE_POLICY=local_and_drive
BACKUP_GDRIVE_RETRY_MAX_ATTEMPTS=8
BACKUP_GDRIVE_RETRY_BASE_SEC=60
BACKUP_GDRIVE_RETRY_MAX_SEC=21600
# Drive retention — independent from local BACKUP_KEEP_LAST_*
BACKUP_GDRIVE_RETENTION_CLEANUP_ENABLED=true
BACKUP_GDRIVE_KEEP_LAST_DAILY=14
BACKUP_GDRIVE_KEEP_LAST_WEEKLY=8
BACKUP_GDRIVE_KEEP_LAST_MONTHLY=24
