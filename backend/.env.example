# PostgreSQL — must be a SUPERUSER (or BYPASSRLS) for Phase 1 since improved_schema.sql
# turns FORCE ROW LEVEL SECURITY on. Phase 2 introduces a real RLS context middleware.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wms_db?schema=public

# Backend HTTP port
PORT=3000

# CORS — comma-separated list of allowed origins (Vite dev server default below).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# JWT auth (required for all API routes except `POST /auth/login` and `POST /auth/logout`).
# Use a long random secret in production.
JWT_SECRET=change-me-to-a-long-random-secret
# Access token lifetime (e.g. `8h`, `3600`, `15m`, `7d`).
JWT_EXPIRES_IN=8h

# Client portal (`/api/client/auth/*`) — use a distinct secret in production so internal JWTs never validate as client.
# Defaults to JWT_SECRET if unset (dev only).
CLIENT_JWT_SECRET=
CLIENT_JWT_EXPIRES_IN=8h

# Optional: default tenant header for dev when not embedded in the JWT (still send `X-Company-Id`).
# Seed company id (Acme Imports):
MOCK_COMPANY_ID=00000000-0000-4000-8000-000000000001

# Task workflow — when true, receiveLine only updates line qty (dock types: input/transit/iss); stock posts on putaway task.
TASK_WORKFLOW_INBOUND_RECEIVE_DEFERS_PUTAWAY=false
# When true, outbound confirm skips stock deduction; ledger posts when dispatch warehouse task completes.
TASK_WORKFLOW_OUTBOUND_CONFIRM_DEFERS_DEDUCTION=false

# Unified cutover (DEFAULT ON when unset): order confirm boots warehouse workflows (receive→qc→putaway; pick→pack→dispatch);
# disables inbound line receive API and outbound atomic deduct-from-confirm.
# Set to false / 0 / no / off for legacy flows only.
# TASK_ONLY_FLOWS=false

# Redis (optional; REDIS_ENABLED=false disables client for dev without Redis)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_KEY_PREFIX=wms:

# When true with Redis enabled, hydrates GET /tasks/:id from a short TTL read-through cache (invalidated on task/workflow writes).
TASK_READ_CACHE=false
TASK_READ_CACHE_TTL_SEC=45

# Socket.IO (`/realtime`) uses the same HTTP server. For horizontal scale, add `@socket.io/redis-adapter`
# and wire it in `main.ts` to the Redis instance above (see NestJS + Socket.IO clustering docs).
