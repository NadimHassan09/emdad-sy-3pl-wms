{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    "paths": {
      "@ds": ["../shared/design-system/ui/index.ts"],
      "@ds/*": ["../shared/design-system/ui/*"],
      "@wms/components/*": ["../frontend/src/components/*"],
      "@wms/hooks/*": ["../frontend/src/hooks/*"],
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "react-dom/client": ["./node_modules/@types/react-dom/client"]
    }
  },
  "include": [
    "src",
    "../shared/design-system/ui/**/*.ts",
    "../shared/design-system/ui/**/*.tsx",
    "../shared/design-system/lib/**/*.ts"
  ]
}
